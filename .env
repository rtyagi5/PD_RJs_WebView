# Development Environment Variables
REACT_APP_DEVELOPMENT_MODE=true

# Default Exercise Settings
REACT_APP_DEFAULT_REPS=5
REACT_APP_DEFAULT_SIDE=left
REACT_APP_DEFAULT_EXERCISE=StandingMarch

# Feature Flags
REACT_APP_ALLOW_VIDEO_RECORDING=false
REACT_APP_ALLOW_SKELETON_RECORDING=false

# API Configuration
REACT_APP_TENANT=dev  # Change this to your tenant name if needed

# Optional: Uncomment and modify if you need to point to a local backend
# REACT_APP_API_BASE_URL=http://localhost:5000

# Optional: Debug Mode
# REACT_APP_DEBUG=true
